<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Dark theme — auto-applied when phone is in dark mode -->
    <style name="Theme.KonjureAnalytics" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/konjure_primary</item>
        <item name="colorPrimaryContainer">@color/konjure_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">#1e2130</item>
        <item name="colorOnSurface">#dfe1ea</item>
        <item name="colorOnSurfaceVariant">#9294a8</item>
        <item name="android:statusBarColor">@color/surface_dark</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="TextAppearance.KonjureToolbar" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
    </style>

</resources>
